# --- Postgres ---
POSTGRES_USER=jobops
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=jobops

# --- App ---
JOBOPS_ENV=prod
JOBOPS_LOG_LEVEL=INFO
JOBOPS_TIMEZONE=America/Denver
JOBOPS_POLL_INTERVAL_MINUTES=30
JOBOPS_REPORT_GENERATION_HOUR_LOCAL=4

# --- Optional local LLM enrichment (workstation Ollama over LAN) ---
JOBOPS_OLLAMA_BASE_URL=
JOBOPS_OLLAMA_MODEL=llama3.1

# --- Phase 2: alert mailbox (create a DEDICATED mailbox for job alerts) ---
JOBOPS_IMAP_HOST=
JOBOPS_IMAP_USER=
JOBOPS_IMAP_PASSWORD=

# --- Safety rails ---
JOBOPS_HIGH_VOLUME_DAILY_SUBMIT_ALERT=25
JOBOPS_POLICY_REVIEW_STALE_DAYS=90
